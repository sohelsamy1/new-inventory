# Laravel Standard Gitignore

# Laravel environment
.env
.env.backup
.env.production

# Laravel storage & cache
/storage/*.key
/storage/framework/*
/storage/logs/*
/storage/pail

# Laravel vendor
/vendor

# Laravel compiled files
/public/build
/public/hot
/public/storage

# Uploaded images (your requirement)
/public/uploads/

# Node modules
/node_modules

# PHP tooling
.phpactor.json
.phpunit.result.cache
/.phpunit.cache

# IDEs and editors
/.idea
/.vscode
/.zed
/.nova
/.fleet

# System files
.DS_Store
Thumbs.db

# Homestead files
Homestead.json
Homestead.yaml

# Composer auth
/auth.json

# Logs
*.log
